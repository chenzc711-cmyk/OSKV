.page { padding: 24rpx; }
.hero { background: linear-gradient(135deg, #ffffff, #eff6ff); border: 1rpx solid #dbeafe; border-radius: 32rpx; box-shadow: 0 16rpx 36rpx rgba(37,99,235,.08); margin-bottom: 20rpx; padding: 28rpx; }
.kicker { color: #2563eb; display: block; font-size: 22rpx; font-weight: 800; letter-spacing: 4rpx; text-transform: uppercase; }
.title { color: #0f172a; display: block; font-size: 44rpx; font-weight: 900; margin-top: 8rpx; }
.subtitle { color: #64748b; display: block; font-size: 24rpx; margin-top: 8rpx; }
.nav { margin: 0 -24rpx 22rpx; padding: 0 24rpx; white-space: nowrap; width: auto; }
.nav-btn { background: #fff; border: 1rpx solid #dbeafe; color: #334155; display: inline-flex; font-size: 26rpx; margin-right: 12rpx; min-height: 72rpx; padding: 0 28rpx; }
.nav-btn.active { background: linear-gradient(135deg, #2563eb, #4f46e5); color: #fff; }
.grid { display: grid; gap: 18rpx; margin-bottom: 18rpx; }
.grid.two { grid-template-columns: 1fr 1fr; }
.grid.one { grid-template-columns: 1fr; }
.card, .list-card { background: rgba(255,255,255,.94); border: 1rpx solid #e2e8f0; border-radius: 28rpx; box-shadow: 0 10rpx 26rpx rgba(15,23,42,.05); margin-bottom: 18rpx; padding: 24rpx; }
.metric text, .channel text, .channel-total text { color: #64748b; display: block; font-size: 24rpx; }
.metric strong, .channel strong, .channel-total strong { color: #0f172a; display: block; font-size: 38rpx; margin-top: 10rpx; }
.metric.danger strong { color: #ef4444; }
.channel-total { background: linear-gradient(135deg, #ffffff, #ecfdf5); }
.channel-total strong { color: #10b981; font-size: 48rpx; }
.section-title { color: #0f172a; font-size: 32rpx; font-weight: 900; margin-bottom: 18rpx; }
input, .picker { background: #f8fafc; border: 1rpx solid #cbd5e1; border-radius: 18rpx; color: #0f172a; margin-bottom: 16rpx; min-height: 78rpx; padding: 0 22rpx; }
.primary { background: linear-gradient(135deg, #2563eb, #4f46e5); color: #fff; margin-top: 8rpx; }
.list-card { align-items: center; display: flex; justify-content: space-between; gap: 18rpx; }
.list-card strong { color: #0f172a; display: block; font-size: 29rpx; }
.list-card text { color: #64748b; display: block; font-size: 23rpx; margin-top: 6rpx; }
.right { text-align: right; }
.actions { display: flex; gap: 10rpx; }
@media (max-width: 360px) { .grid.two { grid-template-columns: 1fr; } .list-card { align-items: stretch; flex-direction: column; } .right { text-align: left; } }
